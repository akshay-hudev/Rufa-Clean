{
  "name": "pdmv2",
  "version": "1.0.0",
  "description": "Repository discovery and classification service",
  "main": "dist/index.js",
  "bin": {
    "dcav2": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "cron": "ts-node src/cron.ts",
    "dca": "ts-node src/cli.ts",
    "runner:image": "docker build -t dcav2-runner:milestone -f Dockerfile.runner .",
    "test": "vitest run",
    "start": "node dist/index.js",
    "sync": "ts-node src/index.ts"
  },
  "knip": {
    "entry": [
      "src/index.ts",
      "src/cron.ts",
      "src/confidence/run-all.ts",
      "src/confidence/review.ts",
      "src/remediation/barrel-removal.ts",
      "scripts/*.ts",
      "src/**/*.test.ts",
      "src/indexing/analyzers/__fixtures__/**/*.ts",
      "test-fixtures/**/*.ts"
    ],
    "project": [
      "src/**/*.ts",
      "scripts/**/*.ts",
      "test-fixtures/**/*.ts"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "type": "commonjs",
  "dependencies": {
    "@sourcegraph/scip-typescript": "0.4.0",
    "dotenv": "^17.4.2",
    "node-cron": "^4.6.0",
    "octokit": "^5.0.5",
    "pg": "^8.22.0",
    "simple-git": "^3.36.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "knip": "^6.26.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
