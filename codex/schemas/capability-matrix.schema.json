{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcav2.local/schemas/capability-matrix.schema.json",
  "title": "DCAv2 Capability Matrix",
  "description": "Defines the machine-readable structure for reporting DCAv2 capability scope, implementation status, validation status, security requirements, limitations, and scale boundaries. A capability matrix describes observed and planned support. It does not authorize implementation, repository access, credential use, external operations, remediation, publication, deployment, infrastructure modification, merge, or destructive operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "title",
    "purpose",
    "document_status",
    "implementation_authorized_by_matrix",
    "status_vocabulary",
    "defaults",
    "capabilities",
    "reporting"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "matrix_id": {
      "$ref": "#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "document_status": {
      "enum": [
        "draft",
        "active",
        "deprecated",
        "superseded"
      ]
    },
    "implementation_authorized_by_matrix": {
      "const": false
    },
    "supersedes_matrix_id": {
      "$ref": "#/$defs/identifier"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_revision": {
      "$ref": "#/$defs/source_revision"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document_reference"
      },
      "uniqueItems": true
    },
    "status_vocabulary": {
      "$ref": "#/$defs/status_vocabulary"
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "matrix_summary": {
      "$ref": "#/$defs/matrix_summary"
    },
    "reporting": {
      "$ref": "#/$defs/reporting"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "capability_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^[a-z0-9][a-z0-9._-]*\\.v[0-9]+$"
    },
    "phase_id": {
      "enum": [
        "phase-0-reconciliation",
        "phase-1-typescript-vertical-slice",
        "phase-2-qualification-and-configuration",
        "phase-3a-npm-monorepos",
        "phase-3b-pnpm",
        "phase-3c-yarn",
        "phase-3d-tsx-and-frameworks",
        "phase-4-python",
        "phase-5-additional-language",
        "phase-6-cross-repository",
        "phase-7-contracts-and-microservices",
        "phase-8-infrastructure-and-runtime",
        "phase-9-campaigns-and-control-plane",
        "phase-10-scale-validation"
      ]
    },
    "source_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "worktree_status": {
          "enum": [
            "clean",
            "modified",
            "untracked",
            "conflicted",
            "unknown"
          ]
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "document_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "support_status": {
      "enum": [
        "planned",
        "experimental",
        "detection_only",
        "partially_supported",
        "functional",
        "blocked",
        "unsupported",
        "deprecated",
        "superseded"
      ]
    },
    "implementation_status": {
      "enum": [
        "not_started",
        "in_progress",
        "partial",
        "implemented",
        "blocked",
        "not_applicable"
      ]
    },
    "validation_status": {
      "enum": [
        "not_run",
        "passed",
        "failed",
        "partial",
        "blocked",
        "unavailable",
        "stale",
        "not_applicable"
      ]
    },
    "scale_status": {
      "enum": [
        "not_validated",
        "validated_within_profile",
        "validated_with_limitations",
        "partially_validated",
        "failed",
        "blocked",
        "stale",
        "not_applicable"
      ]
    },
    "lifecycle_status": {
      "enum": [
        "proposed",
        "active",
        "deprecated",
        "superseded",
        "retired"
      ]
    },
    "status_vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_statuses",
        "implementation_statuses",
        "validation_statuses",
        "scale_statuses",
        "lifecycle_statuses"
      ],
      "properties": {
        "support_statuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/support_status"
          },
          "allOf": [
            {
              "contains": {
                "const": "planned"
              }
            },
            {
              "contains": {
                "const": "detection_only"
              }
            },
            {
              "contains": {
                "const": "partially_supported"
              }
            },
            {
              "contains": {
                "const": "functional"
              }
            },
            {
              "contains": {
                "const": "blocked"
              }
            },
            {
              "contains": {
                "const": "unsupported"
              }
            }
          ]
        },
        "implementation_statuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/implementation_status"
          }
        },
        "validation_statuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/validation_status"
          }
        },
        "scale_statuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/scale_status"
          }
        },
        "lifecycle_statuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/lifecycle_status"
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknown_support_status",
        "missing_validation_status",
        "unavailable_test_result",
        "skipped_test_result",
        "stale_evidence_result",
        "authorization_inference",
        "perfect_detection_claim",
        "phase_transition_authority"
      ],
      "properties": {
        "unknown_support_status": {
          "const": "blocked"
        },
        "missing_validation_status": {
          "const": "not_run"
        },
        "unavailable_test_result": {
          "const": "not_passed"
        },
        "skipped_test_result": {
          "const": "not_passed"
        },
        "stale_evidence_result": {
          "const": "stale"
        },
        "authorization_inference": {
          "const": "prohibited"
        },
        "perfect_detection_claim": {
          "const": "prohibited"
        },
        "phase_transition_authority": {
          "const": "none"
        },
        "unsupported_scope_result": {
          "enum": [
            "unsupported",
            "partially_supported",
            "blocked"
          ]
        },
        "failed_required_control_result": {
          "enum": [
            "blocked",
            "partially_supported"
          ]
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "title",
        "description",
        "domain",
        "version",
        "lifecycle_status",
        "support_status",
        "implementation_status",
        "validation_status",
        "introduced_in_phase",
        "authorization_required",
        "trust_boundary",
        "scope",
        "operations",
        "security_control_ids",
        "limitations",
        "evidence"
      ],
      "properties": {
        "capability_id": {
          "$ref": "#/$defs/capability_id"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "enum": [
            "governance",
            "authorization",
            "repository-access",
            "qualification",
            "runtime-resolution",
            "package-management",
            "inventory",
            "analysis",
            "evidence",
            "coverage",
            "classification",
            "human-review",
            "remediation",
            "verification",
            "patch",
            "publication",
            "audit",
            "database",
            "security",
            "cross-repository",
            "contracts",
            "infrastructure",
            "runtime",
            "campaign",
            "control-plane",
            "reporting",
            "scale",
            "other"
          ]
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle_status": {
          "$ref": "#/$defs/lifecycle_status"
        },
        "support_status": {
          "$ref": "#/$defs/support_status"
        },
        "implementation_status": {
          "$ref": "#/$defs/implementation_status"
        },
        "validation_status": {
          "$ref": "#/$defs/validation_status"
        },
        "introduced_in_phase": {
          "$ref": "#/$defs/phase_id"
        },
        "last_validated_in_phase": {
          "$ref": "#/$defs/phase_id"
        },
        "supersedes_capability_id": {
          "$ref": "#/$defs/capability_id"
        },
        "superseded_by_capability_id": {
          "$ref": "#/$defs/capability_id"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "authorization_required": {
          "const": true
        },
        "trust_boundary": {
          "$ref": "#/$defs/trust_boundary"
        },
        "scope": {
          "$ref": "#/$defs/capability_scope"
        },
        "operations": {
          "$ref": "#/$defs/operation_scope"
        },
        "support_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/support_profile"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability_dependency"
          }
        },
        "tool_dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tool_dependency"
          }
        },
        "security_control_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "test_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_reference"
          }
        },
        "evidence": {
          "$ref": "#/$defs/capability_evidence"
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/limitation"
          }
        },
        "known_blockers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blocker"
          }
        },
        "scale_validation": {
          "$ref": "#/$defs/scale_validation"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "reporting": {
          "$ref": "#/$defs/capability_reporting"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "support_status": {
                "const": "functional"
              }
            },
            "required": [
              "support_status"
            ]
          },
          "then": {
            "properties": {
              "implementation_status": {
                "const": "implemented"
              },
              "validation_status": {
                "const": "passed"
              }
            },
            "required": [
              "test_references"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "support_status": {
                "const": "detection_only"
              }
            },
            "required": [
              "support_status"
            ]
          },
          "then": {
            "properties": {
              "operations": {
                "properties": {
                  "remediation_supported": {
                    "const": false
                  },
                  "publication_supported": {
                    "const": false
                  }
                },
                "required": [
                  "remediation_supported",
                  "publication_supported"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "support_status": {
                "const": "blocked"
              }
            },
            "required": [
              "support_status"
            ]
          },
          "then": {
            "required": [
              "known_blockers"
            ],
            "properties": {
              "known_blockers": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "support_status": {
                "enum": [
                  "deprecated",
                  "superseded"
                ]
              }
            },
            "required": [
              "support_status"
            ]
          },
          "then": {
            "properties": {
              "lifecycle_status": {
                "enum": [
                  "deprecated",
                  "superseded",
                  "retired"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "operations": {
                "properties": {
                  "remediation_supported": {
                    "const": true
                  }
                },
                "required": [
                  "remediation_supported"
                ]
              }
            },
            "required": [
              "operations"
            ]
          },
          "then": {
            "properties": {
              "operations": {
                "required": [
                  "remediation_profile_ids",
                  "human_disposition_required",
                  "separate_remediation_authorization_required",
                  "exact_reproduction_required",
                  "baseline_verification_required",
                  "post_change_verification_required",
                  "changed_file_allowlist_required"
                ],
                "properties": {
                  "remediation_profile_ids": {
                    "minItems": 1
                  },
                  "human_disposition_required": {
                    "const": true
                  },
                  "separate_remediation_authorization_required": {
                    "const": true
                  },
                  "exact_reproduction_required": {
                    "const": true
                  },
                  "baseline_verification_required": {
                    "const": true
                  },
                  "post_change_verification_required": {
                    "const": true
                  },
                  "changed_file_allowlist_required": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "operations": {
                "properties": {
                  "publication_supported": {
                    "const": true
                  }
                },
                "required": [
                  "publication_supported"
                ]
              }
            },
            "required": [
              "operations"
            ]
          },
          "then": {
            "properties": {
              "operations": {
                "required": [
                  "trusted_publisher_required",
                  "separate_publication_authorization_required",
                  "draft_pull_request_only",
                  "direct_default_branch_push",
                  "merge",
                  "auto_merge",
                  "automatic_ready_transition"
                ],
                "properties": {
                  "trusted_publisher_required": {
                    "const": true
                  },
                  "separate_publication_authorization_required": {
                    "const": true
                  },
                  "draft_pull_request_only": {
                    "const": true
                  },
                  "direct_default_branch_push": {
                    "const": "prohibited"
                  },
                  "merge": {
                    "const": "prohibited"
                  },
                  "auto_merge": {
                    "const": "prohibited"
                  },
                  "automatic_ready_transition": {
                    "const": "prohibited"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_zone",
        "repository_content_trusted",
        "structured_output_validation_required"
      ],
      "properties": {
        "execution_zone": {
          "enum": [
            "governance",
            "trusted_controller",
            "untrusted_runner",
            "trusted_publisher",
            "trusted_database",
            "external_read_only",
            "external_write",
            "mixed"
          ]
        },
        "repository_content_trusted": {
          "const": false
        },
        "structured_output_validation_required": {
          "const": true
        },
        "trusted_credentials_permitted": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "prohibited_credentials": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "network_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "runner_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "capability_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_type",
        "bounded",
        "open_world_behavior"
      ],
      "properties": {
        "scope_type": {
          "enum": [
            "governance",
            "single_repository",
            "single_package",
            "monorepo",
            "repository_set",
            "service_set",
            "contract_set",
            "environment_set",
            "campaign",
            "system",
            "other"
          ]
        },
        "bounded": {
          "const": true
        },
        "open_world_behavior": {
          "enum": [
            "not_applicable",
            "preserve_unknown_scope",
            "complete_only_when_all_required_dimensions_complete"
          ]
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "package_managers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "contract_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "infrastructure_providers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "runtime_systems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "repository_visibility": {
          "type": "array",
          "items": {
            "enum": [
              "public",
              "private",
              "internal",
              "unknown"
            ]
          },
          "uniqueItems": true
        },
        "target_shapes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "excluded_shapes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "maximum_tested_scope": {
          "$ref": "#/$defs/tested_scope"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "operation_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detection_supported",
        "classification_supported",
        "remediation_supported",
        "publication_supported",
        "deployment_supported",
        "infrastructure_modification_supported",
        "destructive_operations_supported"
      ],
      "properties": {
        "detection_supported": {
          "type": "boolean"
        },
        "classification_supported": {
          "type": "boolean"
        },
        "human_review_supported": {
          "type": "boolean"
        },
        "remediation_supported": {
          "type": "boolean"
        },
        "publication_supported": {
          "type": "boolean"
        },
        "deployment_supported": {
          "const": false
        },
        "infrastructure_modification_supported": {
          "const": false
        },
        "destructive_operations_supported": {
          "const": false
        },
        "external_reads_supported": {
          "type": "boolean"
        },
        "external_writes_supported": {
          "type": "boolean"
        },
        "remediation_profile_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "human_disposition_required": {
          "type": "boolean"
        },
        "separate_remediation_authorization_required": {
          "type": "boolean"
        },
        "exact_reproduction_required": {
          "type": "boolean"
        },
        "baseline_verification_required": {
          "type": "boolean"
        },
        "post_change_verification_required": {
          "type": "boolean"
        },
        "changed_file_allowlist_required": {
          "type": "boolean"
        },
        "trusted_publisher_required": {
          "type": "boolean"
        },
        "separate_publication_authorization_required": {
          "type": "boolean"
        },
        "draft_pull_request_only": {
          "type": "boolean"
        },
        "direct_default_branch_push": {
          "enum": [
            "prohibited",
            "not_applicable"
          ]
        },
        "merge": {
          "enum": [
            "prohibited",
            "not_applicable"
          ]
        },
        "auto_merge": {
          "enum": [
            "prohibited",
            "not_applicable"
          ]
