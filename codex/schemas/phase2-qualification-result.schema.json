{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcav2.local/schemas/phase2-qualification-result.schema.json",
  "title": "DCAv2 Phase 2 Qualification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "requestDigest",
    "repository",
    "resolvedCommit",
    "sourceSnapshotId",
    "profile",
    "languages",
    "packageManager",
    "workspace",
    "roots",
    "tools",
    "commandObservations",
    "commandMappings",
    "configuration",
    "baseline",
    "capabilityRoutes",
    "blockers",
    "warnings",
    "status",
    "qualificationDigest"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "requestId": { "type": "string", "minLength": 1 },
    "requestDigest": { "$ref": "#/$defs/sha256" },
    "repository": {
      "type": "object",
      "required": ["provider", "owner", "name", "fullName"],
      "properties": {
        "provider": { "const": "github" },
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "fullName": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "providerRepositoryId": { "type": "string", "minLength": 1 }
      }
    },
    "resolvedCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "sourceSnapshotId": { "$ref": "#/$defs/sha256" },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "status", "reasons"],
      "properties": {
        "id": { "const": "typescript-single-package-npm-v1" },
        "version": { "const": "1" },
        "status": { "enum": ["matched", "not_matched", "ambiguous"] },
        "reasons": { "$ref": "#/$defs/strings" }
      }
    },
    "languages": { "type": "array", "items": { "type": "object" } },
    "packageManager": { "type": "object" },
    "workspace": { "type": "object" },
    "roots": { "type": "array", "items": { "type": "object" } },
    "tools": { "type": "array", "items": { "type": "object" } },
    "commandObservations": { "type": "array", "items": { "type": "object" } },
    "commandMappings": { "type": "array", "items": { "type": "object" } },
    "configuration": { "type": "object" },
    "baseline": { "type": "array", "items": { "type": "object" } },
    "capabilityRoutes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilityId", "status", "reasons"],
        "properties": {
          "capabilityId": { "type": "string", "minLength": 1 },
          "status": {
            "enum": [
              "enabled",
              "enabled_with_limits",
              "configuration_required",
              "blocked_by_baseline",
              "blocked_by_security",
              "unsupported",
              "unavailable",
              "stale"
            ]
          },
          "reasons": { "$ref": "#/$defs/strings" }
        }
      }
    },
    "blockers": { "$ref": "#/$defs/strings" },
    "warnings": { "$ref": "#/$defs/strings" },
    "status": {
      "enum": [
        "ready",
        "ready_with_limited_gates",
        "configuration_required",
        "baseline_broken",
        "unsupported",
        "inaccessible",
        "failed",
        "stale",
        "security_blocked",
        "authorization_rejected"
      ]
    },
    "qualificationDigest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "strings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
