          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/destructive_operation"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "allowed": {
                "const": true
              }
            },
            "required": [
              "allowed"
            ]
          },
          "then": {
            "required": [
              "operations"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "allowed": {
                "const": false
              }
            },
            "required": [
              "allowed"
            ]
          },
          "then": {
            "properties": {
              "operations": {
                "maxItems": 0
